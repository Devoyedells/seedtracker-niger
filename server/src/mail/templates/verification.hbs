<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Verify your email</title>
  </head>
  <body
    style="margin:0;padding:0;background-color:#f3f4f6;font-family:'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;"
  >
    <table
      role='presentation'
      width='100%'
      cellpadding='0'
      cellspacing='0'
      style='background-color:#f3f4f6;padding:40px 0;'
    >
      <tr>
        <td align='center'>
          <!-- Main card -->
          <table
            role='presentation'
            width='560'
            cellpadding='0'
            cellspacing='0'
            style='background-color:#ffffff;border-radius:24px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08);'
          >

            <!-- Header -->
            <tr>
              <td
                style='background: linear-gradient(135deg, #008751 0%, #006b40 100%);padding:40px 48px 32px;'
              >
                <table
                  role='presentation'
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                >
                  <tr>
                    <td>
                      <span
                        style='font-size:22px;font-weight:800;color:#ffffff;letter-spacing:-0.5px;'
                      >Seed Tracker NG</span>
                    </td>
                  </tr>
                  <tr>
                    <td style='padding-top:20px;'>
                      <h1
                        style='margin:0;font-size:28px;font-weight:900;color:#ffffff;line-height:1.2;letter-spacing:-0.5px;'
                      >Verify Your Email</h1>
                      <p
                        style='margin:8px 0 0;font-size:15px;color:rgba(255,255,255,0.7);line-height:1.5;'
                      >One step away from joining the network.</p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style='padding:40px 48px;'>
                <p
                  style='margin:0 0 8px;font-size:16px;color:#374151;line-height:1.6;'
                >
                  Hello,
                  <strong style='color:#111827;'>{{fullName}}</strong>
                </p>
                <p
                  style='margin:0 0 32px;font-size:15px;color:#6b7280;line-height:1.6;'
                >
                  Use the verification code below to complete your registration.
                  Enter it on the verification screen. Do not share it with
                  anyone.
                </p>

                <!-- Code display -->
                <table
                  role='presentation'
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                >
                  <tr>
                    <td align='center' style='padding:8px 0 8px;'>
                      <table
                        role='presentation'
                        cellpadding='0'
                        cellspacing='0'
                      >
                        <tr>
                          {{#each codeDigits}}
                            <td style='padding:0 5px;'>
                              <div
                                style="width:52px;height:64px;background:linear-gradient(180deg, #f0fdf4 0%, #ecfccb 100%);border:2px solid #008751;border-radius:16px;text-align:center;line-height:64px;font-size:32px;font-weight:900;color:#008751;letter-spacing:2px;font-family:'Segoe UI',Roboto,'Helvetica Neue',Arial,monospace;"
                              >
                                {{this}}
                              </div>
                            </td>
                          {{/each}}
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <!-- Expiry notice -->
                <table
                  role='presentation'
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                  style='margin-top:28px;'
                >
                  <tr>
                    <td align='center'>
                      <div
                        style='display:inline-block;background-color:#fefce8;border:1px solid #fde68a;border-radius:12px;padding:12px 24px;'
                      >
                        <span
                          style='font-size:13px;font-weight:700;color:#92400e;'
                        >⏱ This code expires in 10 minutes</span>
                      </div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Divider -->
            <tr>
              <td style='padding:0 48px;'>
                <div
                  style='height:1px;background:linear-gradient(90deg, transparent 0%, #e5e7eb 20%, #e5e7eb 80%, transparent 100%);'
                ></div>
              </td>
            </tr>

            <!-- Security footer -->
            <tr>
              <td style='padding:28px 48px 36px;'>
                <p
                  style='margin:0;font-size:13px;color:#9ca3af;line-height:1.6;text-align:center;'
                >
                  If you didn't create an account on Seed Tracker NG, you can
                  safely ignore this email. This code was generated
                  automatically, please do not reply.
                </p>
              </td>
            </tr>

          </table>

          <!-- Bottom branding -->
          <table
            role='presentation'
            width='560'
            cellpadding='0'
            cellspacing='0'
            style='margin-top:24px;'
          >
            <tr>
              <td align='center' style='padding:0 48px;'>
                <p
                  style='margin:0;font-size:12px;color:#9ca3af;font-weight:600;'
                >
                  ©
                  {{year}}
                  Seed Tracker NG · Nigeria's Seed Value Chain Platform
                </p>
              </td>
            </tr>
          </table>

        </td>
      </tr>
    </table>
  </body>
</html>